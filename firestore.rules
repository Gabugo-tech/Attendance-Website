rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidStudent(data) {
      return data.id is string
          && data.name is string && data.name.size() <= 150
          && data.regNo is string && data.regNo.size() <= 50
          && data.department is string && data.department.size() <= 100
          && data.photoUrl is string
          && (data.faceEncodings == null || data.faceEncodings is list);
    }

    // Students
    match /students/{studentId} {
      allow read: if isSignedIn(); // Requires authentication to read student biometric roster
      allow create, update: if isSignedIn() && isValidId(studentId) && isValidStudent(request.resource.data);
      allow delete: if false;
    }

    // Courses
    match /courses/{courseCode} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Let authorized admin/lecturers configure courses
    }

    // Sessions
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(sessionId) && request.resource.data.courseCode is string;
      allow delete: if false;
    }

    // Records
    match /records/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recordId) && request.resource.data.studentId is string && request.resource.data.sessionId is string;
      allow update: if isSignedIn() && isValidId(recordId);
      allow delete: if false;
    }
  }
}
